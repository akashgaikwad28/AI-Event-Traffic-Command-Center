FROM python:3.11-slim
WORKDIR /app

# Install ML dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy ML API and artifacts
COPY ml_pipeline/ /app/ml_pipeline/
COPY backend/app/ai/artifacts/ /app/artifacts/

EXPOSE 8001
CMD ["uvicorn", "ml_pipeline.inference.api:app", "--host", "0.0.0.0", "--port", "8001"]
